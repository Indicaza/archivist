diff --git a/frontend/src/components/workbench/WorkbenchShell.tsx b/frontend/src/components/workbench/WorkbenchShell.tsx
new file mode 100644
index 0000000..77a5e4a
--- /dev/null
+++ b/frontend/src/components/workbench/WorkbenchShell.tsx
@@ -0,0 +1,351 @@
+import {
+  type CSSProperties,
+  type PointerEvent,
+  type ReactNode,
+  useEffect,
+  useRef,
+  useState,
+} from "react";
+import {
+  ChevronDown,
+  ChevronUp,
+  Maximize2,
+  MessageSquareText,
+  Minimize2,
+} from "lucide-react";
+import { Sidebar } from "../sidebar/Sidebar";
+import styles from "./WorkbenchShell.module.css";
+
+type WorkbenchShellProps = {
+  leftPanel: ReactNode;
+  rightPanel: ReactNode;
+  center: ReactNode;
+  bottomToolbar: ReactNode;
+  bottomContent: ReactNode;
+};
+
+type StoredLayout = {
+  leftWidth: number;
+  rightWidth: number;
+  bottomHeight: number;
+  leftCollapsed: boolean;
+  rightCollapsed: boolean;
+  bottomCollapsed: boolean;
+};
+
+type ResizeKind = "left" | "right" | "bottom";
+
+const STORAGE_KEY = "archivist.workbench.layout.v1";
+const DEFAULT_LEFT_WIDTH = 320;
+const DEFAULT_RIGHT_WIDTH = 320;
+const DEFAULT_BOTTOM_HEIGHT = 330;
+const MIN_SIDEBAR_WIDTH = 240;
+const MAX_SIDEBAR_WIDTH = 560;
+const MIN_CENTER_WIDTH = 360;
+const MIN_BOTTOM_HEIGHT = 190;
+const COLLAPSED_BOTTOM_HEIGHT = 43;
+const MIN_CENTER_HEIGHT = 96;
+
+function getWorkbenchHeight(): number {
+  const topbarHeight = Number.parseFloat(
+    getComputedStyle(document.documentElement).getPropertyValue(
+      "--topbar-height",
+    ),
+  );
+
+  return window.innerHeight - (Number.isFinite(topbarHeight) ? topbarHeight : 42);
+}
+
+function clamp(value: number, minimum: number, maximum: number): number {
+  return Math.min(Math.max(value, minimum), Math.max(minimum, maximum));
+}
+
+function readStoredLayout(): StoredLayout | null {
+  try {
+    const rawValue = window.localStorage.getItem(STORAGE_KEY);
+
+    if (!rawValue) {
+      return null;
+    }
+
+    return JSON.parse(rawValue) as StoredLayout;
+  } catch {
+    return null;
+  }
+}
+
+export function WorkbenchShell({
+  leftPanel,
+  rightPanel,
+  center,
+  bottomToolbar,
+  bottomContent,
+}: WorkbenchShellProps) {
+  const storedLayout = useRef(readStoredLayout());
+
+  const [leftWidth, setLeftWidth] = useState(
+    storedLayout.current?.leftWidth ?? DEFAULT_LEFT_WIDTH,
+  );
+  const [rightWidth, setRightWidth] = useState(
+    storedLayout.current?.rightWidth ?? DEFAULT_RIGHT_WIDTH,
+  );
+  const [bottomHeight, setBottomHeight] = useState(
+    storedLayout.current?.bottomHeight ?? DEFAULT_BOTTOM_HEIGHT,
+  );
+
+  const [leftCollapsed, setLeftCollapsed] = useState(
+    storedLayout.current?.leftCollapsed ?? false,
+  );
+  const [rightCollapsed, setRightCollapsed] = useState(
+    storedLayout.current?.rightCollapsed ?? false,
+  );
+  const [bottomCollapsed, setBottomCollapsed] = useState(
+    storedLayout.current?.bottomCollapsed ?? false,
+  );
+  const [bottomMaximized, setBottomMaximized] = useState(false);
+
+  const previousBottomHeightRef = useRef(bottomHeight);
+
+  useEffect(() => {
+    const nextLayout: StoredLayout = {
+      leftWidth,
+      rightWidth,
+      bottomHeight,
+      leftCollapsed,
+      rightCollapsed,
+      bottomCollapsed,
+    };
+
+    window.localStorage.setItem(STORAGE_KEY, JSON.stringify(nextLayout));
+  }, [
+    bottomCollapsed,
+    bottomHeight,
+    leftCollapsed,
+    leftWidth,
+    rightCollapsed,
+    rightWidth,
+  ]);
+
+  useEffect(() => {
+    function clampLayoutToViewport() {
+      const availableHeight = Math.max(
+        MIN_BOTTOM_HEIGHT,
+        getWorkbenchHeight() - MIN_CENTER_HEIGHT,
+      );
+
+      setBottomHeight((current) =>
+        clamp(current, MIN_BOTTOM_HEIGHT, availableHeight),
+      );
+
+      const availableSidebarWidth = Math.max(
+        MIN_SIDEBAR_WIDTH,
+        window.innerWidth - MIN_CENTER_WIDTH,
+      );
+
+      setLeftWidth((current) =>
+        clamp(current, MIN_SIDEBAR_WIDTH, availableSidebarWidth),
+      );
+
+      setRightWidth((current) =>
+        clamp(current, MIN_SIDEBAR_WIDTH, availableSidebarWidth),
+      );
+    }
+
+    window.addEventListener("resize", clampLayoutToViewport);
+
+    clampLayoutToViewport();
+
+    return () => {
+      window.removeEventListener("resize", clampLayoutToViewport);
+    };
+  }, []);
+
+  function beginResize(kind: ResizeKind, event: PointerEvent<HTMLDivElement>) {
+    event.preventDefault();
+
+    const startX = event.clientX;
+    const startY = event.clientY;
+    const startingLeftWidth = leftWidth;
+    const startingRightWidth = rightWidth;
+    const startingBottomHeight = bottomHeight;
+
+    document.body.classList.add(styles.resizing);
+
+    function handlePointerMove(pointerEvent: globalThis.PointerEvent) {
+      if (kind === "left") {
+        const rightSpace = rightCollapsed ? 0 : rightWidth;
+        const maximum = Math.min(
+          MAX_SIDEBAR_WIDTH,
+          window.innerWidth - rightSpace - MIN_CENTER_WIDTH,
+        );
+
+        setLeftWidth(
+          clamp(
+            startingLeftWidth + pointerEvent.clientX - startX,
+            MIN_SIDEBAR_WIDTH,
+            maximum,
+          ),
+        );
+        return;
+      }
+
+      if (kind === "right") {
+        const leftSpace = leftCollapsed ? 0 : leftWidth;
+        const maximum = Math.min(
+          MAX_SIDEBAR_WIDTH,
+          window.innerWidth - leftSpace - MIN_CENTER_WIDTH,
+        );
+
+        setRightWidth(
+          clamp(
+            startingRightWidth + startX - pointerEvent.clientX,
+            MIN_SIDEBAR_WIDTH,
+            maximum,
+          ),
+        );
+        return;
+      }
+
+      const maximum = getWorkbenchHeight() - MIN_CENTER_HEIGHT;
+
+      setBottomCollapsed(false);
+      setBottomMaximized(false);
+      setBottomHeight(
+        clamp(
+          startingBottomHeight + startY - pointerEvent.clientY,
+          MIN_BOTTOM_HEIGHT,
+          maximum,
+        ),
+      );
+    }
+
+    function handlePointerUp() {
+      document.body.classList.remove(styles.resizing);
+      window.removeEventListener("pointermove", handlePointerMove);
+      window.removeEventListener("pointerup", handlePointerUp);
+    }
+
+    window.addEventListener("pointermove", handlePointerMove);
+    window.addEventListener("pointerup", handlePointerUp);
+  }
+
+  function toggleBottomMaximized() {
+    if (bottomMaximized) {
+      setBottomHeight(previousBottomHeightRef.current);
+      setBottomMaximized(false);
+      setBottomCollapsed(false);
+      return;
+    }
+
+    previousBottomHeightRef.current = bottomHeight;
+    setBottomHeight(getWorkbenchHeight() - MIN_CENTER_HEIGHT);
+    setBottomCollapsed(false);
+    setBottomMaximized(true);
+  }
+
+  const visibleLeftWidth = leftCollapsed ? 0 : leftWidth;
+  const visibleRightWidth = rightCollapsed ? 0 : rightWidth;
+  const visibleBottomHeight = bottomCollapsed
+    ? COLLAPSED_BOTTOM_HEIGHT
+    : bottomHeight;
+
