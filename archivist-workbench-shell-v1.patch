+            <span>Chat</span>
+          </div>
+
+          <div className={styles.bottomToolbar}>{bottomToolbar}</div>
+
+          <div className={styles.bottomActions}>
+            <button
+              className={styles.panelButton}
+              type="button"
+              onClick={toggleBottomMaximized}
+              aria-label={
+                bottomMaximized ? "Restore chat panel" : "Maximize chat panel"
