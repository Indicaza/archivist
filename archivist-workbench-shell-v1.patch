+    "--workbench-bottom-height": `${visibleBottomHeight}px`,
+    "--workbench-bottom-space": `${visibleBottomHeight}px`,
+  } as CSSProperties;
+
+  return (
+    <div className={styles.shell} style={shellStyle}>
+      <Sidebar
+        side="left"
+        title="Library Explorer"
+        collapsed={leftCollapsed}
+        onToggle={() => setLeftCollapsed((current) => !current)}
+        onResizeStart={(event) => beginResize("left", event)}
+      >
+        {leftPanel}
+      </Sidebar>
+
+      <main className={styles.center}>{center}</main>
+
+      <Sidebar
+        side="right"
+        title="Chat Controls"
+        collapsed={rightCollapsed}
+        onToggle={() => setRightCollapsed((current) => !current)}
+        onResizeStart={(event) => beginResize("right", event)}
+      >
+        {rightPanel}
+      </Sidebar>
+
+      <section
+        className={`${styles.bottomPanel} ${
+          bottomCollapsed ? styles.bottomCollapsed : ""
+        }`}
+        aria-label="Chat panel"
+      >
+        <div
+          className={styles.bottomResizeHandle}
+          role="separator"
+          aria-orientation="horizontal"
+          aria-label="Resize chat panel"
+          onPointerDown={(event) => beginResize("bottom", event)}
+          onDoubleClick={toggleBottomMaximized}
+        />
+
+        <header className={styles.bottomHeader}>
+          <div className={styles.bottomTab}>
